      setQuizResult(null);
      return;
    }

    const score = quizAnswers.reduce(
      (sum, selectedIndex, index) => sum + quizQuestions[index].options[selectedIndex].score,
      0,
    );

    setQuizResult(getQuizProfile(score));
    setQuizError("");
  };

